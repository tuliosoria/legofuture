{
  "name": "legofuture",
  "version": "1.0.0",
  "description": "LEGO Set Investment Forecasting",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "sync": "node scripts/sync-pricecharting-to-dynamo.mjs",
    "sync:pricecharting": "node --env-file=.env.local scripts/sync-pricecharting-to-dynamo.mjs",
    "sync:rebrickable": "node --env-file=.env.local scripts/sync-rebrickable-catalog.mjs",
    "sync:bricklink": "node --env-file=.env.local scripts/sync-bricklink-pricing.mjs",
    "sync:brickset": "node --env-file=.env.local scripts/sync-brickset-enrichment.mjs",
    "sync:ebay": "node --env-file=.env.local scripts/sync-ebay-sold-listings.mjs",
    "sync:ebay-comps": "node --env-file=.env.local scripts/sync-ebay-comps.mjs",
    "smoke:sync": "node --env-file=.env.local scripts/smoke-test-sync.mjs",
    "sync:images": "node --env-file=.env.local scripts/sync-images.mjs",
    "sync:community": "node --env-file=.env.local scripts/sync-community.mjs",
    "sync:pc-csv": "node --env-file=.env.local scripts/sync-pricecharting-csv.mjs",
    "sync:pc-history": "node --env-file=.env.local scripts/scrape-pricecharting-history.mjs",
    "sync:history-snapshot": "node --env-file=.env.local scripts/backfill-current-month-history.mjs",
    "sync:history-synthesise": "node --env-file=.env.local scripts/synthesise-sparse-history.mjs",
    "sync:trends": "node --env-file=.env.local scripts/sync-google-trends.mjs",
    "sync:bl-validate": "node --env-file=.env.local scripts/validate-bricklink.mjs",
    "setup:ddb": "bash scripts/setup-dynamodb.sh",
    "infra:build": "cd infra/lego-ml-retrainer && sam build || echo 'sam build skipped (SAM CLI not installed locally)'",
    "ml:train": "python3 lego-ml/train.py",
    "ml:retrain": "python3 lego-ml/retrain.py",
    "verify:scripts": "node --env-file=.env.local scripts/verify-syncs.mjs",
    "sync:curated-scores": "node --env-file=.env.local scripts/sync-external-scores.mjs",
    "sync:candidates": "node --env-file=.env.local scripts/sync-candidates.mjs",
    "sync:all": "bash scripts/sync-all.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "hooks:install": "git config core.hooksPath .githooks",
    "verify": "npm run lint && npm run test && npm run build",
    "train:lego": "bash scripts/train-lego-model.sh"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1032.0",
    "@aws-sdk/lib-dynamodb": "^3.1032.0",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "google-trends-api": "^4.9.2",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "oauth-1.0a": "^2.2.6",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^29.1.1",
    "vitest": "^2.1.9"
  }
}
