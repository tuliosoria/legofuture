# Copy this file to .env.local for local development.
# .env* is gitignored; never commit real values.

# AWS / DynamoDB runtime
# Reads use the default AWS credential chain (env vars, ~/.aws/credentials, IAM role).
AWS_REGION=us-east-1
DYNAMODB_TABLE=pokeinvest-cache

# Provider credentials (optional)
# Only needed for one-time PokeData backfills or live population enrichment.
PRICECHARTING_API_TOKEN=

# --- BrickLink (recommended — biggest coverage win, ~95% of LEGO sets) -------
# Register at https://www.bricklink.com/v2/api/register_consumer.page
# All four values are required; if any is blank, the BL sync is skipped.
BRICKLINK_CONSUMER_KEY=
BRICKLINK_CONSUMER_SECRET=
BRICKLINK_TOKEN_VALUE=
BRICKLINK_TOKEN_SECRET=

# --- Brickset (current retail + retirement metadata) -------------------------
# Register at https://brickset.com/tools/webservices/requestkey
BRICKSET_API_KEY=
BRICKSET_USERNAME=
BRICKSET_PASSWORD=

# --- eBay (sold listings, best for retired/rare sets) ------------------------
# Register at https://developer.ebay.com/my/keys
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# --- Rebrickable (LEGO catalog metadata + images) ----------------------------
# Register at https://rebrickable.com/api/
REBRICKABLE_API_KEY=

# Sealed ML runtime
# auto    -> prefer published DynamoDB models, fall back to bundled JSON artifacts
# bundled -> ignore published DynamoDB models and force the repo-bundled rollback copy
SEALED_ML_MODEL_SOURCE=auto

# Sealed ML retrainer
# false lets you capture outcomes and retrain without publishing new model chunks.
SEALED_ML_PUBLISH_ENABLED=false
# Optional local override for retraining output artifacts
SEALED_ML_OUTPUT_DIR=src/lib/data/sealed-ml

# Owned immutable asset/history storage (optional)
OWNED_DATA_ASSET_BUCKET=
OWNED_DATA_ASSET_PREFIX=owned-data

# Launch/legal content
LEGAL_OPERATOR_NAME=PokeFuture
LEGAL_CONTACT_EMAIL=hello@pokefuture.com
PRIVACY_REQUEST_EMAIL=privacy@pokefuture.com
LEGAL_BUSINESS_ADDRESS=See contact page
LEGAL_CONTACT_URL=

# Public site URL used for canonical links, sitemap, OG metadata.
# Defaults to https://www.pokefuture.com if unset.
NEXT_PUBLIC_SITE_URL=https://www.pokefuture.com

# GA4 measurement ID. If unset, GA4 will not load. Set this in production.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-NFE3MG3QZE
