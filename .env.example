# ── PriceCharting ─────────────────────────────────────────────────────────────
# Required for live price lookups. Without this, the app falls back to the
# bundled pricecharting-current-prices.json snapshot.
PRICECHARTING_API_TOKEN=your_token_here

# ── AWS / DynamoDB ─────────────────────────────────────────────────────────────
# Optional. When unset the app runs entirely from bundled JSON (no caching).
AWS_REGION=us-east-1
DYNAMODB_TABLE=legofuture-cache

# ── Rebrickable ────────────────────────────────────────────────────────────────
# Optional. Used to enrich catalog metadata (set images, piece counts).
REBRICKABLE_API_KEY=your_key_here

# ── Legal / Branding ──────────────────────────────────────────────────────────
# Shown in Privacy Policy, Terms of Use, and Contact pages.
LEGAL_OPERATOR_NAME=LegoFuture
LEGAL_CONTACT_EMAIL=hello@legofuture.com
PRIVACY_REQUEST_EMAIL=privacy@legofuture.com
LEGAL_BUSINESS_ADDRESS="123 Brick Lane, LEGO City"
LEGAL_CONTACT_URL=https://github.com/tuliosoria/legofuture/issues
